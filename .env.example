# ===========================================
# Intelligent Emergency Response System
# Copy this file to .env and fill in your values.
# ===========================================

# --- Database ---
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/emergency_db?retryWrites=true&w=majority&appName=Cluster0

# --- Server ---
PORT=5000
API_URL=http://localhost:5000
VITE_API_URL=http://localhost:5000

# --- FCM (Push) — use Firebase service account JSON file ---
# Path to your firebase-key.json (e.g. at project root: firebase-key.json)
# Do not use FCM_SERVER_KEY; the app uses the JSON file only.
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-key.json
FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# --- Mail (e.g. Gmail) — for guardian/SOS alerts ---
MAIL_USERNAME=
MAIL_PASSWORD=
GUARDIAN_ALERT_EMAIL=

# --- Maps (optional) — app works without these ---
# "Respond Now" opens Google Maps with lat/lng; no key needed.
# Set only if you add in-app map tiles or geocoding.
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=

# --- Image upload (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
UPLOAD_API_URL=

# --- SMS (Twilio, optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Mobile ---
# Run after editing .env:  npm run sync-env
# Syncs API_URL; GOOGLE_MAPS/MAPBOX optional (can be empty).
