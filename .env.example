# ===========================================
# SheGuard — Intelligent Emergency Response System
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# ===========================================
# All frontends (Police web, Home app, Me app) use the same API URL from here.
# Run from repo root after editing:  npm run sync-env  (updates mobile apps' config)
# ===========================================

# --- Database ---
# Replace <user> and <password> with your MongoDB Atlas credentials.
# Do NOT use angle brackets in the actual password.
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/emergency_db?retryWrites=true&w=majority&appName=Cluster0

# --- Shared API (used by all frontends) ---
# Backend base URL. Use your machine IP (e.g. http://192.168.1.5:5000) when testing mobile on device.
API_URL=http://localhost:5000
# Same value for web PCR (Vite reads this)
VITE_API_URL=http://localhost:5000
PORT=5000

# --- Email-only alerts (hackathon / no SMS) ---
# SMS is paid; for hackathon we use email only. Set your Gmail (or SMTP) and alert recipients here.
# MAIL_USERNAME / MAIL_PASSWORD: account that sends emails (e.g. Gmail + app password).
# GUARDIAN_ALERT_EMAIL: primary email to receive SOS, tamper, check-in alerts.
# ALERT_EMAILS: optional comma-separated list of extra emails (guardians, police demo, etc.).
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
GUARDIAN_ALERT_EMAIL=guardian@example.com
ALERT_EMAILS=police-demo@example.com,second-guardian@example.com

# --- FCM (Push) — optional ---
# Path to Firebase service account JSON (e.g. at project root: firebasekey.json).
FIREBASE_SERVICE_ACCOUNT_PATH=firebasekey.json
FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# --- Maps (optional) ---
# "Respond Now" works with Google Maps URL without a key. Set only for in-app maps/geocoding.
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=

# --- Image upload (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
UPLOAD_API_URL=

# --- Auth (victim, guardian, PCR) ---
# Used by /api/auth for JWT tokens and session expiry.
# Victim/Guardian: register with email (verify) → login with phone + password.
# PCR: register with station details → login with stationId + password (POST /api/auth/login-pcr).
JWT_SECRET=your-secret-min-32-chars-for-production
JWT_EXPIRES_IN=30d
SESSION_INACTIVITY_DAYS=30

# --- CORS (optional) ---
# Production: CORS_ORIGIN=https://yourdomain.com
# Default * allows all (fine for dev/hackathon).
# CORS_ORIGIN=*

# --- Mobile config sync ---
# After editing .env run:  npm run sync-env
# This writes API_URL (as BASE_URL), GOOGLE_MAPS, MAPBOX, FCM sender ID into:
#   mobile-victim/src/config/config.js
#   mobile-guardian/src/config/config.js

# --- SMS (Twilio) — not used for hackathon ---
# Alerts go by email only. Uncomment if you add SMS later.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
